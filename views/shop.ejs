<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Scatch Shop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f1f5f9;
        }

        header {
            background: white;
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .logo {
            font-size: 22px;
            font-weight: 600;
            color: #2563eb;
        }

        .logout-btn {
            background: #ef4444;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
        }

        .container {
            max-width: 1200px;
            margin: 50px auto;
            padding: 0 20px;
        }

        h1 {
            margin-bottom: 30px;
        }

        .products {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 25px;
        }

        .card {
            border-radius: 16px;
            overflow: hidden;
            transition: 0.3s ease;
        }

        .card:hover {
            transform: translateY(-6px);
        }

       .image {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8fafc;
}

        .content {
            padding: 20px;
        }

        .price {
            font-weight: 600;
            margin: 10px 0;
        }

        .old-price {
            text-decoration: line-through;
            opacity: 0.6;
            margin-right: 10px;
        }

        .discount-badge {
            background: #ef4444;
            color: white;
            padding: 3px 8px;
            border-radius: 6px;
            font-size: 12px;
        }

        .buy-btn {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            margin-top: 15px;
            font-weight: 500;
        }

    </style>
</head>
<body>

<header>
    <div class="logo">Scatch Shop</div>
    <form action="/users/logout" method="GET">
        <button class="logout-btn">Logout</button>
    </form>
</header>

<div class="container">
    <h1>Our Products 🛍️</h1>

    <div class="products">

        <% products.forEach(product => { %>

            <% 
               const finalPrice = product.price - 
               (product.price * product.discount / 100); 
            %>

            <div class="card" style="background-color: <%= product.bgColor %>">

           <div class="image">
    <img 
        src="images/uploads/<%= product.image %>" 
        alt="<%= product.name %>" 
        style="width:100%; height:100%; object-fit:contain;"
    >
</div>

                <div class="content" 
                     style="background-color: <%= product.panelColor %>; 
                            color: <%= product.textColor %>">

                    <h3><%= product.name %></h3>

                    <div class="price">
                        <% if(product.discount > 0) { %>
                            <span class="old-price">₹<%= product.price %></span>
                            ₹<%= finalPrice.toFixed(0) %>
                            <span class="discount-badge">
                                -<%= product.discount %>%
                            </span>
                        <% } else { %>
                            ₹<%= product.price %>
                        <% } %>
                    </div>

                    <button class="buy-btn" 
                        style="background-color: <%= product.textColor %>;
                               color: white;">
                        Add to Cart
                    </button>

                </div>

            </div>

        <% }) %>

    </div>
</div>

</body>
</html>